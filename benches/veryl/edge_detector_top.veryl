module Top (
    clk      : input  clock,
    rst      : input  reset,
    i_data   : input  logic<32>,
    o_edge   : output logic<32>,
    o_posedge: output logic<32>,
    o_negedge: output logic<32>,
) {
    inst u: edge_detector #(WIDTH: 32) (
        i_clk  : clk,
        i_rst  : rst,
        i_clear: 1'b0,
        i_data,
        o_edge,
        o_posedge,
        o_negedge,
    );
}
